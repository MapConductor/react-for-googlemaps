{
  "name": "@mapconductor/google-maps",
  "version": "0.1.0",
  "description": "Google Maps provider for MapConductor React SDK",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rm -rf dist",
    "test": "echo 'No tests yet'"
  },
  "keywords": [
    "maps",
    "google-maps",
    "react",
    "typescript"
  ],
  "author": "MapConductor",
  "license": "MIT",
  "peerDependencies": {
    "@mapconductor/core": "^0.1.0",
    "react": "^19.2.0"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.1.1",
    "@mapconductor/core": "workspace:*",
    "@mapconductor/react": "workspace:*"
  },
  "devDependencies": {
    "@types/google.maps": "^3.65.2",
    "react": "^19.2.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
